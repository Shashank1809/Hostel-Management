@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <title>Create User - Hostel Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f0f8f5;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .reg-box {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            width: 450px;
        }

        .btn-custom {
            background-color: #4CAF50;
            color: white;
            width: 100%;
            margin-top: 15px;
        }

            .btn-custom:hover {
                background-color: #45a049;
                color: white;
            }
        /* Style for the new Admin Button */
        .btn-admin {
            background-color: #343a40;
            color: white;
            width: 100%;
            margin-top: 10px;
        }

            .btn-admin:hover {
                background-color: #23272b;
                color: white;
            }
    </style>
</head>
<body>
    <div class="reg-box text-center">
        <h2 class="mb-4 fw-bold">Create User</h2> <form action="@Url.Action("Register", "Account")" method="post">
            <div class="row">
                <div class="col-md-6 mb-3 text-start">
                    <label class="fw-bold">First Name</label>
                    <input type="text" name="FirstName" class="form-control" placeholder="First" required />
                </div>
                <div class="col-md-6 mb-3 text-start">
                    <label class="fw-bold">Last Name</label>
                    <input type="text" name="LastName" class="form-control" placeholder="Last" required />
                </div>
            </div>
            <div class="mb-3 text-start">
                <label class="fw-bold">Username</label> <input type="text" name="Username" class="form-control" placeholder="Enter Username" required />
            </div>
            <div class="mb-3 text-start">
                <label class="fw-bold">Email</label> <input type="email" name="Email" class="form-control" placeholder="Enter Email" required />
            </div>
            <div class="mb-3 text-start">
                <label class="fw-bold">Password</label> <input type="password" name="Password" class="form-control" placeholder="Enter Password" required />
            </div>

            <button type="submit" class="btn btn-custom">CREATE AND ACCESS</button>
        </form>

        <a href="@Url.Action("Login", "Account", new { type = "Admin" })" class="btn btn-admin">Admin Login</a>

        <p class="mt-3"><a href="@Url.Action("Login", "Account")" style="color: #4CAF50;">Back to Student Login</a></p>
    </div>
</body>
</html>