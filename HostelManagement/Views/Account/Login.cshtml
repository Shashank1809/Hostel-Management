@{
    Layout = null;
    // Dynamically check if the user clicked the Admin Login button
    string loginType = Request.QueryString["type"] == "Admin" ? "Admin" : "Student";
}
<!DOCTYPE html>
<html>
<head>
    <title>@loginType Login - Hostel Management</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        body {
            background-color: #f0f8f5;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .login-box {
            background: white;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            width: 350px;
            text-align: center;
        }

        .btn-custom {
            background-color: #4CAF50;
            color: white;
            width: 100%;
            margin-top: 15px;
        }

            .btn-custom:hover {
                background-color: #45a049;
                color: white;
            }
        /* Style for the new Admin Button */
        .btn-admin {
            background-color: #343a40;
            color: white;
            width: 100%;
            margin-top: 10px;
        }

            .btn-admin:hover {
                background-color: #23272b;
                color: white;
            }
    </style>
</head>
<body>
    <div class="login-box">
        @if (loginType == "Admin")
        {
            @*<img src="https://via.placeholder.com/100/343a40/FFFFFF?text=Admin" class="rounded-circle mb-3" alt="Admin Avatar" />*@
            <h3 class="mb-3 fw-bold">Admin Login</h3>
        }
        else
        {
            @*<img src="https://via.placeholder.com/100/4CAF50/FFFFFF?text=User" class="rounded-circle mb-3" alt="User Avatar" />*@
            <h3 class="mb-3 fw-bold">Student Login</h3>
        }

        <form action="@Url.Action("Login", "Account")" method="post">
            <div class="mb-3 text-start">
                <label class="fw-bold">Username</label> <input type="text" name="username" class="form-control" placeholder="Enter Username" required />
            </div>
            <div class="mb-3 text-start">
                <label class="fw-bold">Password</label> <input type="password" name="password" class="form-control" placeholder="Enter Password" required />
            </div>
            @if (ViewBag.Error != null)
            {<p class="text-danger">@ViewBag.Error</p>}

            <button type="submit" class="btn btn-custom">Login</button>
        </form>

        @if (loginType == "Student")
        {
            <a href="@Url.Action("Login", "Account", new { type = "Admin" })" class="btn btn-admin">Admin Login</a>
        }
        else
        {
            <a href="@Url.Action("Login", "Account")" class="btn btn-outline-success w-100 mt-2">Student Login</a>
        }

        <p class="mt-3"><a href="@Url.Action("Register", "Account")" style="color: #4CAF50;">Create User</a></p>
    </div>
</body>
</html>