@model IEnumerable<HostelManagement.Models.Booking>
@{
    ViewBag.Title = "Student Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-12">
            <div class="p-4 bg-primary text-white rounded shadow-sm d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="mb-1">Student Dashboard</h2>
                    <p class="mb-0">Welcome back, @Session["Username"]. Here is your active housing information.</p>
                </div>
                <div class="text-end d-none d-md-block">
                    <span class="fs-1">🎓</span>
                </div>
            </div>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow-sm border-0 border-top border-primary border-4">
                <div class="card-header bg-white border-bottom pt-3 pb-3">
                    <h5 class="mb-0 fw-bold">My Booked Rooms</h5>
                </div>
                <div class="card-body p-0">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4 py-3">Room Details</th>
                                <th>Monthly Rent</th>
                                <th>Booking Date</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td class="ps-4 py-3">
                                            @if (item.Room != null)
                                            {
                                                <strong class="text-dark">@item.Room.RoomType</strong><br />
                                                <small class="text-muted">@item.Room.Description</small>
                                            }
                                            else
                                            {
                                                <span>Room ID: @item.RoomId</span>
                                            }
                                        </td>
                                        <td class="text-success fw-bold">
                                            $@(item.Room != null ? item.Room.MonthlyRent.ToString("0.00") : "N/A")
                                        </td>
                                        <td>@item.BookingDate.ToString("MMM dd, yyyy")</td>
                                        <td>
                                            @if (item.Status == "Active")
                                            {
                                                <span class="badge bg-success px-2 py-1">Active</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary px-2 py-1">@item.Status</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center py-5 text-muted">
                                        <h6 class="fw-normal mb-3">You haven't booked any rooms yet.</h6>
                                        <a href="@Url.Action("Index", "Room")" class="btn btn-outline-primary px-4">Browse Available Rooms</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>