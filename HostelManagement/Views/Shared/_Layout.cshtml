<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Hostel Management</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>
        body {
            background-color: #f8f9fa;
        }

        .navbar-custom {
            background-color: #4CAF50;
        }
            /* Theme Green */
            .navbar-custom .navbar-brand, .navbar-custom .nav-link {
                color: white;
                font-weight: 500;
            }

                .navbar-custom .nav-link:hover {
                    color: #e8e8e8;
                }

        .footer {
            position: fixed;
            bottom: 0;
            width: 100%;
            background-color: #ffffff;
            padding: 15px 0;
            text-align: center;
            border-top: 1px solid #ddd;
        }

        .body-content {
            padding-bottom: 70px;
        }
        /* Prevent footer overlap */
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-custom shadow-sm mb-4">
        <div class="container">
            <a class="navbar-brand" href="@Url.Action("Admin", "Dashboard")">🏨 Hostel Management</a>
            <div class="collapse navbar-collapse d-flex justify-content-end">
                <ul class="navbar-nav">
                    @if (Session["UserRole"] != null)
                    {
                        <li class="nav-item">
                            <span class="nav-link">Hello, @Session["Username"]</span>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Logout", "Account")">Logout</a>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="@Url.Action("Login", "Account")">Login</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <div class="container body-content">
        @RenderBody()
    </div>

    <footer class="footer">
        <div class="container">
            <p class="mb-0 text-muted">&copy; @DateTime.Now.Year - Hostel Management System</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>