@model IEnumerable<HostelManagement.Models.Room>
@{
    ViewBag.Title = "Hostel Rooms";
    // Check if the logged-in user is an Admin
    bool isAdmin = Session["UserRole"] != null && Session["UserRole"].ToString() == "Admin";
}

<h2 class="mb-4">Available Rooms</h2>

@if (isAdmin)
{
    <p>
        <a href="@Url.Action("Create", "Room")" class="btn btn-success shadow-sm">+ Add New Room</a>
    </p>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th>Room Type</th>
                    <th>Description</th>
                    <th>Monthly Rent</th>
                    <th>Status</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.RoomType</td>
                            <td>@item.Description</td>
                            <td>$@item.MonthlyRent</td>
                            <td>
                                @if (item.IsAvailable)
                                {
                                    <span class="badge bg-success">Available</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Occupied</span>
                                }
                            </td>
                            <td>
                                @if (isAdmin)
                                {
                                    <a href="@Url.Action("Edit", "Room", new { id = item.RoomId })" class="btn btn-sm btn-primary px-3 me-1">Edit</a>
                                    <a href="@Url.Action("Delete", "Room", new { id = item.RoomId })" class="btn btn-sm btn-danger px-3">Delete</a>
                                }
                                else
                                {
                                    if (item.IsAvailable)
                                    {
                                        <a href="@Url.Action("Book", "Room", new { id = item.RoomId })" class="btn btn-sm btn-success px-3">Book Room</a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-secondary px-3" disabled>Full</button>
                                    }
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No rooms are currently available in the database.
                            @(isAdmin ? "Click 'Add New Room' to create one." : "")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>