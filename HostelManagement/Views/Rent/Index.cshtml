@{
    ViewBag.Title = "Rent Management";
    bool isAdmin = Session["UserRole"] != null && Session["UserRole"].ToString() == "Admin";
}

<h2 class="mb-4">Rent & Mess Management</h2>

@if (isAdmin)
{
    <button class="btn btn-success mb-3">+ Add Payment Record</button>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Transaction ID</th>
                    @if (isAdmin)
                    {
                        <th>Student Name</th>
}
                    <th>Description</th>
                    <th>Amount</th>
                    <th>Date</th>
                    <th>Status</th>
                    @if (isAdmin)
                    {
                        <th>Action</th>
}
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td>#TXN-1001</td>
                    @if (isAdmin)
                    {
                        <td>@Session["Username"]</td>
}
                    <td>Monthly Room Rent</td>
                    <td>$250.00</td>
                    <td>@DateTime.Now.ToString("MMM dd, yyyy")</td>
                    <td><span class="badge bg-success">Paid</span></td>
                    @if (isAdmin)
                    {
                        <td>
                            <button class="btn btn-sm btn-primary">Edit</button>
                            <button class="btn btn-sm btn-danger">Delete</button>
                        </td>
                    }
                </tr>
            </tbody>
        </table>
    </div>
</div>