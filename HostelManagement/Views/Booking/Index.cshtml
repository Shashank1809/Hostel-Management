@model IEnumerable<HostelManagement.Models.Booking>
@{
    ViewBag.Title = "Manage Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📅 Room Bookings Overview</h2>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-0">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">Booking ID</th>
                    <th>Student Details</th>
                    <th>Room Details</th>
                    <th>Booking Date</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var booking in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold text-muted">@booking.BookingId</td>
                            <td>
                                @if (booking.User != null)
                                {
                                    <strong>@booking.User.FirstName @booking.User.LastName</strong><br />
                                    <small class="text-muted">@booking.User.Username</small>
                                }
                                else
                                {
                                    <span class="text-danger">User Deleted (ID: @booking.UserId)</span>
                                }
                            </td>

                            <td>
                                @if (booking.Room != null)
                                {
                                    <strong>@booking.Room.RoomType</strong><br />
                                    <small class="text-success">$@booking.Room.MonthlyRent / month</small>
                                }
                                else
                                {
                                    <span class="text-danger">Room Deleted (ID: @booking.RoomId)</span>
                                }
                            </td>

                            <td>@booking.BookingDate.ToString("MMM dd, yyyy")</td>

                            <td>
                                @if (booking.Status == "Active")
                                {
                                    <span class="badge bg-success px-2 py-1">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary px-2 py-1">@booking.Status</span>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-5">
                            <h5 class="fw-normal">No bookings have been made yet.</h5>
                            <p>When students book rooms, they will appear here.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>



